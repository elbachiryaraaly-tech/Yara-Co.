# Database (PostgreSQL local: puerto 5432 por defecto)
# Si usas Docker: puerto 5433. Usuario/contraseña según tu instalación.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/yaraluxe?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# URL base para enlaces en emails (verificación, etc.). Si usas ngrok en NEXTAUTH_URL, pon aquí http://localhost:3000 o tu dominio real.
SITE_URL="http://localhost:3000"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Dropshipping (AliExpress / CJ / Printful / BigBuy)
ALIEXPRESS_API_KEY=""
ALIEXPRESS_API_SECRET=""
CJ_API_KEY=""
# Printful: Private Token (opcional; también puedes configurarlo en Admin → Proveedores → Configurar API → Access Token)
# PRINTFUL_ACCESS_TOKEN=""
# BigBuy: token API (opcional; también en Admin → Proveedores → Configurar API → API Key)
# BIGBUY_API_KEY=""
# CJ: pago automático por balance. Si defines estos dos, los pedidos se crean con createOrderV2 y CJ cobra de tu balance y procesa al instante.
# Obtén el nombre de logística en CJ (ej. "Standard Shipping", "YunExpress") o desde la API de freight.
# CJ_DEFAULT_LOGISTIC_NAME=""
# CJ_FROM_COUNTRY_CODE="CN"

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="YaraLuxe <noreply@yaraluxe.com>"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Analytics
NEXT_PUBLIC_GA_ID="G-..."
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=""
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""

# Hero video (opcional): URL directa a un .mp4 para el fondo del hero
# Ejemplo: descarga un video en Pexels/Pixabay y súbelo a /public/videos/hero.mp4 → NEXT_PUBLIC_HERO_VIDEO_URL="/videos/hero.mp4"
NEXT_PUBLIC_HERO_VIDEO_URL=""

# Cron (automatización: reintento dropshipping, sync tracking, renovar token AliExpress)
# Genera un valor secreto y ponlo aquí; el cron debe llamar con Authorization: Bearer <CRON_SECRET> o ?secret=<CRON_SECRET>
# En Vercel: Crons usa la URL del proyecto y no envía headers; configura CRON_SECRET en Variables de entorno.
CRON_SECRET=""

# Admin
ADMIN_EMAIL="admin@yaraluxe.com"
